AUTH_REFRESH_TOKEN_SECRET=troque-esta-chave-de-refresh
AUTH_ACCESS_TOKEN_EXPIRES_IN=15m
AUTH_REFRESH_TOKEN_EXPIRES_IN=30d
AUTH_JWT_ISSUER=leadsroute-api
AUTH_JWT_AUDIENCE=leadsroute-web
AUTH_EMAIL_ENABLED=true
