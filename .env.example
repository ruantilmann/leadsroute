NEXT_PUBLIC_AUTH_ACCESS_COOKIE_NAME=lr_access_token
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com/v1
GOOGLE_PLACES_TIMEOUT_MS=10000
GOOGLE_PLACES_MAX_RETRIES=2
GOOGLE_PLACES_LANGUAGE=pt-BR
GOOGLE_PLACES_REGION=BR
APP_BASE_URL=http://localhost:3000
AUTH_ACCESS_COOKIE_NAME=lr_access_token
AUTH_REFRESH_COOKIE_NAME=lr_refresh_token
